# Profila Environment Configuration
# Copy this file to .env and customize for your environment

# Output Configuration
PROFILA_OUTPUT_DIR=./output
PROFILA_LOG_LEVEL=INFO

# Profiling Configuration
PROFILA_SAMPLE_RATE=1000
PROFILA_MAX_DEPTH=10

# System Metrics
PROFILA_METRICS_INTERVAL=5
PROFILA_DISK_WARNING_THRESHOLD=90
PROFILA_MEMORY_WARNING_THRESHOLD=85

# Development Settings
PROFILA_ENV=development
PROFILA_DEBUG=false

# Optional Integrations
# SENTRY_DSN=
# GRAFANA_API_KEY=
# PROMETHEUS_ENDPOINT=
